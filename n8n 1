        "jsCode": "/*\n  Загружаем финальное видео в Supabase Storage.\n*/\nconst prev = $('15. FFmpeg команда').first().json;\nconst workDir = prev.workDir;\nconst outputFinal = prev.outputFinal;\nconst supaUrl = prev.supabaseUrl;\nconst sKey = $env.SUPABASE_SERVICE_ROLE_KEY || '';\n\nconst fs = require('fs');\n\n// Читаем файл\nlet fileBuffer;\ntry {\n  fileBuffer = fs.readFileSync(outputFinal);\n} catch(e) {\n  // Если final не существует, пробуем merged\n  try {\n    fileBuffer = fs.readFileSync(`${workDir}/merged.mp4`);\n  } catch(e2) {\n    return [{ json: { error: 'No output video file found', workDir } }];\n  }\n}\n\nconst fileName = `result_${Date.now()}.mp4`;\nconst path = `results/${fileName}`;\n\ntry {\n  await this.helpers.httpRequest({\n    method: 'POST',\n    url: `${supaUrl}/storage/v1/object/avd-files/${path}`,\n    headers: {\n      'Authorization': `Bearer ${sKey}`,\n      'apikey': sKey,\n      'Content-Type': 'video/mp4'\n    },\n    body: fileBuffer,\n    returnFullResponse: false\n  });\n} catch(e) {\n  return [{ json: { error: 'Upload failed: ' + e.message } }];\n}\n\nconst publicUrl = `${supaUrl}/storage/v1/object/public/avd-files/${path}`;\n\n// Очистка tmp\ntry {\n  fs.rmSync(workDir, { recursive: true, force: true });\n} catch(e) {}\n\nreturn [{\n  json: {\n    success: true,\n    videoUrl: publicUrl,\n    fileName: fileName,\n    message: 'Video generation completed successfully!'\n  }\n}];"
