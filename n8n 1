    {
      "parameters": {
        "jsCode": "/*\n  Собираем все результаты видео и TTS.\n  Скачиваем файлы на сервер для FFmpeg склейки.\n*/\nconst items = $input.all();\nconst parentData = $('10. Подготовка видеозапросов').first().json._parentData;\n\n// Собираем URL видео по сценам\nconst videoResults = items.map((item, i) => ({\n  sceneIndex: i,\n  videoUrl: item.json?.videoUrl || '',\n  status: item.json?.status || 'unknown'\n}));\n\n// TTS результаты\nconst ttsResults = parentData.ttsResults || [];\n\n// Формируем команды для скачивания\nconst downloadCmds = [];\nconst videoFiles = [];\nconst audioFiles = [];\n\n// Создаём рабочую директорию\nconst workDir = `/tmp/avd_${Date.now()}`;\ndownloadCmds.push(`mkdir -p ${workDir}`);\n\n// Скачиваем референсное видео (сцена 0), если нужно\nif (parentData.useRefAsScene0) {\n  const mainChar = parentData.characters?.[0];\n  if (mainChar?.videoUrl) {\n    const refPath = `${workDir}/scene_ref.mp4`;\n    downloadCmds.push(`curl -sL \"${mainChar.videoUrl}\" -o ${refPath}`);\n    videoFiles.push(refPath);\n  }\n}\n\n// Скачиваем сгенерированные видео\nvideoResults.forEach((vr, i) => {\n  if (vr.videoUrl) {\n    const path = `${workDir}/scene_${i}.mp4`;\n    downloadCmds.push(`curl -sL \"${vr.videoUrl}\" -o ${path}`);\n    videoFiles.push(path);\n  }\n});\n\n// Скачиваем аудио\nttsResults.forEach((tr, i) => {\n  if (tr.audioUrl) {\n    const path = `${workDir}/audio_${i}.mp3`;\n    downloadCmds.push(`curl -sL \"${tr.audioUrl}\" -o ${path}`);\n    audioFiles.push(path);\n  }\n});\n\nreturn [{\n  json: {\n    workDir,\n    downloadCmds,\n    videoFiles,\n    audioFiles,\n    videoResults,\n    ttsResults,\n    supabaseUrl: parentData.supabaseUrl,\n    parentData\n  }\n}];"
      },
      "id": "node-13",
      "name": "13. Сборка результатов",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 460]
    },
    {
      "parameters": {
        "command": "={{ $json.downloadCmds.join(' && ') }}"
      },
      "id": "node-14",
      "name": "14. Скачивание файлов",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [2860, 460]
    },
    {
      "parameters": {
        "jsCode": "/*\n  Формируем команду FFmpeg для склейки видео и наложения аудио.\n*/\nconst prev = $('13. Сборка результатов').first().json;\nconst workDir = prev.workDir;\nconst videoFiles = prev.videoFiles;\nconst audioFiles = prev.audioFiles;\n\nif (videoFiles.length === 0) {\n  return [{ json: { error: 'No video files to merge', workDir } }];\n}\n\nlet ffmpegCmd = '';\nconst outputVideo = `${workDir}/merged.mp4`;\nconst outputFinal = `${workDir}/final.mp4`;\n\n// Шаг 1: Склейка видео\nif (videoFiles.length === 1) {\n  ffmpegCmd = `cp ${videoFiles[0]} ${outputVideo}`;\n} else {\n  // Создаём concat файл\n  const concatList = videoFiles.map(f => `file '${f}'`).join('\\n');\n  ffmpegCmd = `echo \"${concatList}\" > ${workDir}/concat.txt && `;\n  // Ренормализация + склейка\n  const filterParts = videoFiles.map((f, i) => \n    `[${i}:v]scale=1920:1080:force_original_aspect_ratio=decrease,pad=1920:1080:(ow-iw)/2:(oh-ih)/2,setsar=1,fps=30[v${i}]`\n  ).join('; ');\n  const concatInputs = videoFiles.map((f, i) => `-i ${f}`).join(' ');\n  const concatStreams = videoFiles.map((_, i) => `[v${i}]`).join('');\n  \n  ffmpegCmd += `ffmpeg -y ${concatInputs} -filter_complex \"${filterParts}; ${concatStreams}concat=n=${videoFiles.length}:v=1:a=0[outv]\" -map \"[outv]\" -c:v libx264 -preset fast -crf 23 ${outputVideo}`;\n}\n\n// Шаг 2: Наложение аудио\nlet finalCmd = ffmpegCmd;\nif (audioFiles.length > 0) {\n  // Склеиваем все аудио в один файл\n  const mergedAudio = `${workDir}/merged_audio.mp3`;\n  if (audioFiles.length === 1) {\n    finalCmd += ` && cp ${audioFiles[0]} ${mergedAudio}`;\n  } else {\n    const audioInputs = audioFiles.map(f => `-i ${f}`).join(' ');\n    const audioConcat = audioFiles.map((_, i) => `[${i}:a]`).join('');\n    finalCmd += ` && ffmpeg -y ${audioInputs} -filter_complex \"${audioConcat}concat=n=${audioFiles.length}:v=0:a=1[outa]\" -map \"[outa]\" ${mergedAudio}`;\n  }\n  \n  // Наложение аудио на видео (аудио обрезается по длине видео)\n  finalCmd += ` && ffmpeg -y -i ${outputVideo} -i ${mergedAudio} -c:v copy -c:a aac -shortest ${outputFinal}`;\n} else {\n  finalCmd += ` && cp ${outputVideo} ${outputFinal}`;\n}\n\nreturn [{\n  json: {\n    ffmpegCmd: finalCmd,\n    outputFinal,\n    workDir,\n    supabaseUrl: prev.supabaseUrl,\n    parentData: prev.parentData\n  }\n}];"
      },
