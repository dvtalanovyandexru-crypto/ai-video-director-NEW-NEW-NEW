    {
      "parameters": {
        "jsCode": "/*\n  Подготовка видеозапросов — один запрос на каждую сцену.\n  Каждая сцена получает свой промпт с ракурсом, персонажами, действиями.\n*/\nconst data = $input.first().json;\nconst scenes = data.scenes || [];\nconst chars = data.characters || [];\nconst location = data.location || {};\n\nconst anglesMap = {\n  'close-up': 'close-up shot',\n  'medium': 'medium shot',\n  'wide': 'wide establishing shot',\n  'over-shoulder': 'over-the-shoulder shot',\n  'two-shot': 'two-shot'\n};\n\nconst lightMap = {\n  'natural': 'natural daylight',\n  'warm': 'warm candlelight',\n  'cold': 'cool blue lighting',\n  'dramatic': 'dramatic high-contrast lighting',\n  'soft': 'soft diffused lighting'\n};\n\nconst colorMap = {\n  'warm': 'warm color palette',\n  'cold': 'cool color palette',\n  'neutral': 'neutral color palette',\n  'cinematic': 'cinematic color grading'\n};\n\nreturn scenes.map((sc, i) => {\n  // Собираем промпт для сцены\n  const parts = [];\n  \n  // Описание действия\n  if (sc.action) parts.push(sc.action);\n  \n  // Персонажи в сцене\n  const sceneChars = sc.characters.map(ci => chars.find(c => c.index === ci)).filter(Boolean);\n  if (sceneChars.length) {\n    const charDesc = sceneChars.map(c => {\n      let d = c.name;\n      if (c.description) d += ` (${c.description})`;\n      if (c.wardrobeMode === 'change' && c.wardrobeDesc) d += `, wearing ${c.wardrobeDesc}`;\n      else if (c.wardrobeMode === 'keep') d += ', wearing the same outfit as in reference';\n      return d;\n    }).join(' and ');\n    parts.push(`Characters: ${charDesc}`);\n  }\n  \n  // Локация\n  if (location.description) parts.push(`Setting: ${location.description}`);\n  const light = lightMap[location.lighting] || '';\n  const color = colorMap[location.colorScheme] || '';\n  if (light || color) parts.push(`Visual style: ${[light, color].filter(Boolean).join(', ')}`);\n  \n  // Ракурс\n  parts.push(`Camera: ${anglesMap[sc.angle] || 'medium shot'}`);\n  \n  // Доп. указания\n  if (sc.notes) parts.push(sc.notes);\n  \n  // Качество\n  if (data.quality === 'high') parts.push('High quality, cinematic, 1080p, detailed');\n  \n  const prompt = parts.join('. ');\n  \n  // Image reference — берём фото первого персонажа в сцене\n  const mainChar = sceneChars[0];\n  const imageUrl = mainChar?.faceUrl || '';\n  const videoUrl = mainChar?.videoUrl || '';\n  \n  return {\n    json: {\n      _sceneIndex: i,\n      _totalScenes: scenes.length,\n      model: data.videoModel,\n      prompt: prompt,\n      duration: sc.duration || 10,\n      aspect_ratio: data.aspectRatio,\n      quality: data.quality,\n      image_url: imageUrl,\n      video_url: videoUrl,\n      apiKey: data.apiKey,\n      supabaseUrl: data.supabaseUrl,\n      _parentData: {\n        ttsResults: data.ttsResults,\n        characters: data.characters,\n        scenes: data.scenes,\n        useRefAsScene0: data.useRefAsScene0,\n        music: data.music,\n        minimaxKey: data.minimaxKey,\n        apiKey: data.apiKey,\n        supabaseUrl: data.supabaseUrl\n      }\n    }\n  };\n});"
      },
