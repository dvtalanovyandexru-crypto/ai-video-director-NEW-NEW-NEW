    {
      "parameters": {
        "jsCode": "/*\n  Polling статуса видео задачи.\n  Ожидаем завершения генерации.\n*/\nconst item = $input.first().json;\nconst taskId = item?.data?.task_id || item?.id || item?.task_id || '';\nconst apiKey = item?.apiKey || $('10. Подготовка видеозапросов').first().json.apiKey;\n\nif (!taskId) {\n  return [{ json: { error: 'No task_id received', raw: item } }];\n}\n\nconst maxAttempts = 60;\nconst interval = 10000; // 10 сек\n\nfor (let attempt = 0; attempt < maxAttempts; attempt++) {\n  const resp = await this.helpers.httpRequest({\n    method: 'GET',\n    url: `https://apiin.one/api/v1/tasks/${taskId}`,\n    headers: { 'Authorization': `Bearer ${apiKey}` }\n  });\n  \n  const status = resp?.data?.status || resp?.status || '';\n  \n  if (['COMPLETED','completed','SUCCESS','success'].includes(status)) {\n    const videoUrl = resp?.data?.output?.video_url || resp?.data?.video_url || resp?.output?.video_url || '';\n    return [{ json: { taskId, status: 'completed', videoUrl, raw: resp } }];\n  }\n  \n  if (['FAILED','failed','ERROR','error'].includes(status)) {\n    return [{ json: { taskId, status: 'failed', error: resp?.data?.error || 'Generation failed', raw: resp } }];\n  }\n  \n  // Ждём\n  await new Promise(r => setTimeout(r, interval));\n}\n\nreturn [{ json: { taskId, status: 'timeout', error: 'Polling timeout after 10 minutes' } }];"
      },
      "id": "node-12",
      "name": "12. Polling видео",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
