      "parameters": {
        "jsCode": "/*\n  Парсинг входных данных из FormData webhook.\n  Извлекаем JSON payload и файлы.\n*/\nconst items = $input.all();\nconst item = items[0];\n\nlet payload;\ntry {\n  // FormData: payload приходит как строка в поле 'payload'\n  const raw = item.json.payload || item.json.body?.payload || JSON.stringify(item.json);\n  payload = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch(e) {\n  payload = item.json;\n}\n\n// Извлекаем ключи\nconst apiKey = payload.apiKey || '';\nconst minimaxKey = payload.minimaxKey || '';\nconst supabaseUrl = 'https://supabase.fantomnatashi.ru';\n\n// Собираем данные о персонажах\nconst characters = (payload.characters || []).map(c => ({\n  index: c.index,\n  name: c.name,\n  description: c.description,\n  voiceId: c.voiceId,\n  voiceMode: c.voiceMode,\n  wardrobeMode: c.wardrobeMode,\n  wardrobeDesc: c.wardrobeDesc,\n  hasFacePhoto: c.hasFacePhoto,\n  hasVideoRef: c.hasVideoRef\n}));\n\n// Собираем сцены\nconst scenes = (payload.scenes || []).map(sc => ({\n  index: sc.index,\n  duration: sc.duration || 10,\n  angle: sc.angle || 'medium',\n  characters: sc.characters || [],\n  dialog: sc.dialog || '',\n  action: sc.action || '',\n  notes: sc.notes || ''\n}));\n\n// Собираем все диалоги из всех сцен\nconst allDialogs = [];\nscenes.forEach(sc => {\n  if (!sc.dialog) return;\n  sc.dialog.split('\\n').filter(l => l.trim()).forEach(line => {\n    const ci = line.indexOf(':');\n    if (ci > 0) {\n      const name = line.slice(0, ci).trim();\n      const text = line.slice(ci+1).trim();\n      if (text) {\n        // Найти voiceId по имени персонажа\n        const char = characters.find(c => c.name && c.name.toLowerCase() === name.toLowerCase());\n        allDialogs.push({\n          sceneIndex: sc.index,\n          name: name,\n          text: text,\n          voiceId: char?.voiceId || characters[0]?.voiceId || null\n        });\n      }\n    }\n  });\n});\n\nreturn [{\n  json: {\n    apiKey,\n    minimaxKey,\n    supabaseUrl,\n    payload,\n    characters,\n    scenes,\n    allDialogs,\n    videoModel: payload.videoGeneration?.model || 'seedance-2.0',\n    aspectRatio: payload.videoGeneration?.aspectRatio || '16:9',\n    quality: payload.videoGeneration?.quality || 'standard',\n    ttsModel: payload.tts?.model || 'speech-2.8-hd',\n    ttsSpeed: payload.tts?.speed || 1,\n    useRefAsScene0: payload.useRefAsScene0 || false,\n    location: payload.location || {},\n    music: payload.music || {},\n    brief: payload.brief || ''\n  }\n}];"
      },
