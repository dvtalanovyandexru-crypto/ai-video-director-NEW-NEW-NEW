    {
      "parameters": {
        "jsCode": "/*\n  Собираем URL аудио из TTS и сохраняем в Supabase.\n*/\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const audioUrl = item.json?.data?.audio || '';\n  const parentData = item.json?._parentData || $('3. Загрузка файлов в Supabase').first().json;\n  \n  results.push({\n    dialogIndex: item.json?._dialogIndex || 0,\n    sceneIndex: item.json?.sceneIndex || 0,\n    name: item.json?.name || '',\n    text: item.json?.text || '',\n    audioUrl: audioUrl\n  });\n}\n\n// Получаем основные данные из ноды 3\nconst data = $('3. Загрузка файлов в Supabase').first().json;\n\nreturn [{\n  json: {\n    ...data,\n    ttsResults: results\n  }\n}];"
