    {
      "parameters": {
        "jsCode": "/*\n  Загрузка файлов персонажей в Supabase Storage.\n  Получаем публичные URL для фото и видео.\n*/\nconst data = $input.first().json;\nconst supaUrl = data.supabaseUrl;\nconst items = $('1. Webhook').all();\nconst item = items[0];\n\n// Получаем SERVICE_ROLE_KEY из env\nconst sKey = $env.SUPABASE_SERVICE_ROLE_KEY || '';\n\nconst fileUrls = {};\nconst charCount = data.characters.length;\n\n// Ищем бинарные данные в webhook\nconst binData = item.binary || {};\n\nfor (let i = 1; i <= charCount; i++) {\n  fileUrls[i] = { faceUrl: '', videoUrl: '' };\n  \n  // Фото лица\n  const faceKey = `char${i}_face`;\n  if (binData[faceKey]) {\n    const bin = binData[faceKey];\n    const ext = bin.fileExtension || 'jpg';\n    const path = `faces/char${i}_${Date.now()}.${ext}`;\n    try {\n      const resp = await this.helpers.httpRequest({\n        method: 'POST',\n        url: `${supaUrl}/storage/v1/object/avd-files/${path}`,\n        headers: {\n          'Authorization': `Bearer ${sKey}`,\n          'apikey': sKey,\n          'Content-Type': bin.mimeType || 'image/jpeg'\n        },\n        body: Buffer.from(bin.data, 'base64'),\n        returnFullResponse: false\n      });\n      fileUrls[i].faceUrl = `${supaUrl}/storage/v1/object/public/avd-files/${path}`;\n    } catch(e) {\n      fileUrls[i].faceUrl = '';\n    }\n  }\n  \n  // Видео-референс\n  const vidKey = `char${i}_video`;\n  if (binData[vidKey]) {\n    const bin = binData[vidKey];\n    const ext = bin.fileExtension || 'mp4';\n    const path = `videos/char${i}_${Date.now()}.${ext}`;\n    try {\n      await this.helpers.httpRequest({\n        method: 'POST',\n        url: `${supaUrl}/storage/v1/object/avd-files/${path}`,\n        headers: {\n          'Authorization': `Bearer ${sKey}`,\n          'apikey': sKey,\n          'Content-Type': bin.mimeType || 'video/mp4'\n        },\n        body: Buffer.from(bin.data, 'base64'),\n        returnFullResponse: false\n      });\n      fileUrls[i].videoUrl = `${supaUrl}/storage/v1/object/public/avd-files/${path}`;\n    } catch(e) {\n      fileUrls[i].videoUrl = '';\n    }\n  }\n}\n\n// Обновляем данные персонажей с URL\nconst updatedChars = data.characters.map(c => ({\n  ...c,\n  faceUrl: fileUrls[c.index]?.faceUrl || '',\n  videoUrl: fileUrls[c.index]?.videoUrl || ''\n}));\n\nreturn [{\n  json: {\n    ...data,\n    characters: updatedChars,\n    fileUrls\n  }\n}];"
      },
